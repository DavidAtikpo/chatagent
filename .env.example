NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Clé service_role (serveur uniquement — même valeur que api/.env)
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WIDGET_URL=/widget.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Emails autorisés pour /admin (propriétaire SaaS), séparés par des virgules
PLATFORM_ADMIN_EMAILS=vous@exemple.com
